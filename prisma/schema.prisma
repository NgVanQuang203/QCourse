// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ─────────────────────────────────────────────────────────────────────────────
// AUTH (NextAuth.js v5 Prisma Adapter)
// ─────────────────────────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  nickname       String?   @unique
  image          String?                    // Google avatar or uploaded
  avatarColor    String    @default("linear-gradient(135deg,#6366f1,#a855f7)")
  mood           String    @default("😊")
  bio            String?
  passwordHash   String?                    // null = Google-only account

  // Gamification
  streak         Int       @default(0)
  maxStreak      Int       @default(0)
  lastActiveDate String?                    // YYYY-MM-DD (UTC+7)

  // NextAuth relations
  accounts       Account[]
  sessions       Session[]

  // Learning relations
  folders        Folder[]
  decks          Deck[]
  sm2Progress    SM2Progress[]
  activityLogs   ActivityLog[]
  quizAttempts   QuizAttempt[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// LEARNING CONTENT
// ─────────────────────────────────────────────────────────────────────────────
model Folder {
  id     String @id @default(cuid())
  userId String
  name   String
  icon   String @default("📁")

  type   DeckType @default(FLASHCARD)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks  Deck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

enum DeckType {
  FLASHCARD
  QUIZ
}

model Deck {
  id           String   @id @default(cuid())
  userId       String
  folderId     String?
  name         String
  description  String?
  color        String   @default("#6366f1")
  type         DeckType @default(FLASHCARD)
  timeLimitSec Int      @default(60)        // Per-question timer (QUIZ only)
  isPublic     Boolean  @default(false)

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?     @relation(fields: [folderId], references: [id])
  cards        Card[]
  quizAttempts QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
}

model Card {
  id                 String  @id @default(cuid())
  deckId             String

  // Flashcard fields
  front              String  @db.Text
  back               String  @db.Text
  hint               String?
  imageUrl           String?

  // Quiz-specific fields (null for flashcards)
  options            Json?   // String[] — the 4 options A/B/C/D
  correctOptionIndex Int?    // 0-3

  deck               Deck          @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sm2Progress        SM2Progress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deckId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SM-2 SPACED REPETITION
// https://www.supermemo.com/en/archives1990-2015/english/ol/sm2
// ─────────────────────────────────────────────────────────────────────────────
model SM2Progress {
  id           String   @id @default(cuid())
  userId       String
  cardId       String

  // SM-2 state
  interval     Int      @default(1)     // Days until next review
  repetitions  Int      @default(0)     // Consecutive correct answers
  easeFactor   Float    @default(2.5)   // EF ≥ 1.3
  nextDueDate  DateTime @default(now()) // When to show next
  lastReviewed DateTime?
  lastQuality  Int?                     // 0-5 quality of last recall

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])           // One SM-2 record per user per card
  @@index([userId, nextDueDate])       // Key query: cards due today
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY TRACKING (Heatmap & Chart data)
// ─────────────────────────────────────────────────────────────────────────────
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String
  date           String               // YYYY-MM-DD in user's timezone (UTC+7)
  minutesStudied Int      @default(0)
  cardsStudied   Int      @default(0)
  deckIds        String[]             // Which decks were studied

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])            // One row per user per day
  @@index([userId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUIZ ATTEMPTS (full history)
// ─────────────────────────────────────────────────────────────────────────────
model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  deckId         String

  score          Int                  // Number of correct answers
  totalQuestions Int
  timeTakenSec   Int
  grade          String               // "A"/"B"/"C"/"D"/"F"
  // answers: [{cardId, chosenIndex, correctIndex, timeSec}]
  answers        Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([deckId])
}
