generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  emailVerified  DateTime?
  name           String?
  nickname       String?       @unique
  image          String?
  avatarColor    String        @default("linear-gradient(135deg,#6366f1,#a855f7)")
  mood           String        @default("😊")
  bio            String?
  passwordHash   String?
  streak         Int           @default(0)
  maxStreak      Int           @default(0)
  lastActiveDate String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  accounts       Account[]
  activityLogs   ActivityLog[]
  decks          Deck[]
  folders        Folder[]
  quizAttempts   QuizAttempt[]
  sm2Progress    SM2Progress[]
  sessions       Session[]

  @@index([email])
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String   @default("📁")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type      DeckType @default(FLASHCARD)
  decks     Deck[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Deck {
  id           String        @id @default(cuid())
  userId       String
  folderId     String?
  name         String
  description  String?
  color        String        @default("#6366f1")
  type         DeckType      @default(FLASHCARD)
  timeLimitSec Int           @default(60)
  isPublic     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cards        Card[]
  folder       Folder?       @relation(fields: [folderId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempts QuizAttempt[]

  @@index([userId])
  @@index([isPublic])
}

model Card {
  id                 String        @id @default(cuid())
  deckId             String
  front              String
  back               String
  hint               String?
  imageUrl           String?
  options            Json?
  correctOptionIndex Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deck               Deck          @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sm2Progress        SM2Progress[]

  @@index([deckId])
}

model SM2Progress {
  id           String    @id @default(cuid())
  userId       String
  cardId       String
  interval     Int       @default(1)
  repetitions  Int       @default(0)
  easeFactor   Float     @default(2.5)
  nextDueDate  DateTime  @default(now())
  lastReviewed DateTime?
  lastQuality  Int?
  card         Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, nextDueDate])
}

model ActivityLog {
  id             String   @id @default(cuid())
  userId         String
  date           String
  minutesStudied Int      @default(0)
  cardsStudied   Int      @default(0)
  deckIds        String[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  deckId         String
  score          Int
  totalQuestions Int
  timeTakenSec   Int
  grade          String
  answers        Json
  createdAt      DateTime @default(now())
  deck           Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([deckId])
}

enum DeckType {
  FLASHCARD
  QUIZ
}
